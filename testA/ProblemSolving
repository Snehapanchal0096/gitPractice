    public static void evenNumber(int n) {
        int c = 0;
        while (c >= n) {
            if (n % 2 == 0) {
                System.out.print(c + " ");
            }
            c++;
        }
    }


public static void findLargestandSmallestElementBySort(int[] a) {
        System.out.println("findLargestandSmallestElementBySort()");
        int min = a[0];
        int max = a[0];
        for (int j : a) {
            if (j > max) {
                max = j;
            }
            if (j < min) {
                min = j;
            }
        }
        System.out.println("Max: " + max + " Min: " + min);
    }